# Application Settings
APP_NAME=VentureOS Backend
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
API_V1_PREFIX=/api/v1

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=True

# CORS Settings
CORS_ORIGINS=http://localhost:3000,https://ventureos.app
CORS_ALLOW_CREDENTIALS=True

# PostgreSQL Database (Supabase)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ventureos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
DATABASE_URL=postgresql+asyncpg://postgres:your-postgres-password@localhost:5432/ventureos

# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=ventureos_products
MONGODB_USER=mongo
MONGODB_PASSWORD=your-mongo-password
MONGODB_URL=mongodb://mongo:your-mongo-password@localhost:27017/ventureos_products

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_URL=redis://:your-redis-password@localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://:your-redis-password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:your-redis-password@localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=False

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-master-key

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AI Models - Local (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=30

# AI Models - Cloud (OpenRouter)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_BLUEPRINT_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MARKET_MODEL=mistralai/mistral-7b-instruct:free
OPENROUTER_SEO_MODEL=google/gemma-2-9b-it:free

# External APIs
GOOGLE_TRENDS_API_KEY=your-google-trends-key
FACEBOOK_AD_LIBRARY_TOKEN=your-facebook-token
TIKTOK_API_KEY=your-tiktok-api-key

# Payment Gateway (SSLCommerz)
SSLCOMMERZ_STORE_ID=your-store-id
SSLCOMMERZ_STORE_PASSWORD=your-store-password
SSLCOMMERZ_API_URL=https://sandbox.sslcommerz.com
SSLCOMMERZ_VALIDATION_URL=https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php

# Monitoring & Logging
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_FREE_TIER_SEARCHES_PER_DAY=20
RATE_LIMIT_FREE_TIER_BLUEPRINTS_PER_MONTH=1
RATE_LIMIT_PRO_TIER_BLUEPRINTS_PER_MONTH=10

# Scraping Configuration
SCRAPING_ENABLED=True
SCRAPING_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
SCRAPING_TIMEOUT=30
SCRAPING_MAX_RETRIES=3

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Encryption
ENCRYPTION_KEY=your-encryption-key-32-bytes-base64
ENCRYPTION_ALGORITHM=AES-256-GCM

# Feature Flags
ENABLE_MARKETPLACE_INTELLIGENCE=True
ENABLE_RESEARCH_SITE_DATASET=True
ENABLE_AI_FALLBACK=True
ENABLE_CACHE=True
ENABLE_METRICS=True
